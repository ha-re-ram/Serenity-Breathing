{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "totalSessions": { "type": "number" },
        "currentStreak": { "type": "number" },
        "lastSessionDate": { "type": "string", "format": "date-time" },
        "reminderTime": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "totalSessions", "currentStreak"]
    },
    "sessions": {
      "title": "Breathing Session",
      "description": "A completed breathing session",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "mode": { "type": "string", "enum": ["calm", "focus", "sleep", "morning"] },
        "duration": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "moodBefore": { "type": "string" },
        "moodAfter": { "type": "string" }
      },
      "required": ["uid", "mode", "duration", "timestamp"]
    },
    "moods": {
      "title": "Mood Check",
      "description": "User mood check-in",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "mood": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "mood", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profiles"
    },
    "/sessions/{sessionId}": {
      "schema": "sessions",
      "description": "Breathing sessions log"
    },
    "/moods/{moodId}": {
      "schema": "moods",
      "description": "Mood check-ins log"
    }
  }
}
